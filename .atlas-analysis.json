  "keyFeatures": [
    "Small and fast C compiler for multiple architectures (i386, x86_64, ARM, ARM64, RISC-V)",
    "Direct compilation and execution without separate linking step",
    "C scripting support with shebang-style execution",
    "libtcc library for embedding compiler in applications",
    "Automatic memory and bounds checking",
    "JIT compilation and dynamic code generation",
    "ISO C99 compliance with GNU extensions",
    "Self-hosting compiler that can compile itself"
